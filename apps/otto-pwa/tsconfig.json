{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@otto/shared-types": ["../../packages/shared-types/src"],
      "@otto/shared-auth": ["../../packages/shared-auth/src"],
      "@otto/shared-firebase": ["../../packages/shared-firebase/src"],
      "@otto/shared-ui": ["../../packages/shared-ui/src"],
      "@otto/shared-ontology": ["../../packages/shared-ontology/src"],
      "@otto/shared-utils": ["../../packages/shared-utils/src"],
      "@/*": ["./src/*"]
    },
    "noEmit": true
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/shared-auth" },
    { "path": "../../packages/shared-firebase" },
    { "path": "../../packages/shared-ui" },
    { "path": "../../packages/shared-ontology" },
    { "path": "../../packages/shared-utils" }
  ]
}
