{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": ["vite/client", "vite-plugin-pwa/client"],
    "paths": {
      "@/*":                    ["./src/*"],
      "@otto/shared-types":     ["../../packages/shared-types/src/index.ts"],
      "@otto/shared-auth":      ["../../packages/shared-auth/src/index.ts"],
      "@otto/shared-firebase":  ["../../packages/shared-firebase/src/index.ts"],
      "@otto/shared-ui":        ["../../packages/shared-ui/src/index.ts"],
      "@otto/shared-ontology":  ["../../packages/shared-ontology/src/index.ts"],
      "@otto/shared-utils":     ["../../packages/shared-utils/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src"],
  "references": []
}
