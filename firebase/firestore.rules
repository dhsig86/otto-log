rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Surgical Logs ────────────────────────────────────────────
    match /logbooks/{logId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.ownerUid;

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerUid
        && request.resource.data.ownerUid is string
        && request.resource.data.procedureName is string;

      // Imagens do log
      match /images/{imageId} {
        allow read: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/logbooks/$(logId)).data.ownerUid;
        allow write: if false; // Apenas via Cloud Function
      }
    }

    // ── Users ───────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Audit Logs ───────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if false;
      allow write: if false; // Apenas via Cloud Functions
    }

    // ── Ontology ─────────────────────────────────────────────────
    match /ontology/{entryId} {
      allow read: if true; // Público
      allow write: if request.auth.token.admin == true;
    }

    // ── Deny all else ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
